{
  "expo": {
    "name": "Vedic Clock",
    "slug": "vedic-clock",
    "version": "0.1.0",
    "orientation": "landscape",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0D1B2A",
    "primaryColor": "#E8B94B",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1B2A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.varunc28.vedicclock"
    },
    "android": {
      "package": "com.varunc28.vedicclock"
    },
    "androidStatusBar": {
      "hidden": true,
      "translucent": true
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-screen-orientation",
      "./plugins/withKiosk.js",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "2547cdba-e40d-4c94-8469-6fbe82e45dc1"
      }
    }
  }
}
